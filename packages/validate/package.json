{
  "name": "@opentechevents/validate",
  "version": "0.1.0",
  "description": "Validates OTE Event and Feed documents against JSON Schema v0.2",
  "license": "MIT",
  "homepage": "https://github.com/OpenTechEvents/ote-tools/tree/main/packages/validate",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenTechEvents/ote-tools.git",
    "directory": "packages/validate"
  },
  "bugs": "https://github.com/OpenTechEvents/ote-tools/issues",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "ote-validate": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "gen": "node scripts/embed-schemas.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@opentechevents/schema": "0.2.0",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  }
}
