{
  "name": "@opentechevents/export-rss",
  "version": "0.1.0",
  "description": "Converts an OTE Feed into an RSS 2.0 document",
  "license": "MIT",
  "homepage": "https://github.com/OpenTechEvents/ote-tools/tree/main/packages/export-rss",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenTechEvents/ote-tools.git",
    "directory": "packages/export-rss"
  },
  "bugs": "https://github.com/OpenTechEvents/ote-tools/issues",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "ote-export-rss": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentechevents/validate": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  }
}
