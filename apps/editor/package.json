{
  "name": "@opentechevents/editor",
  "version": "0.1.0",
  "description": "Static web editor for OTE events: form → event JSON → prefilled issue or direct edit",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --serve",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentechevents/build-feed": "workspace:*",
    "@opentechevents/import-ics": "workspace:*",
    "@opentechevents/import-jsonld": "workspace:*",
    "@opentechevents/validate": "workspace:*",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
